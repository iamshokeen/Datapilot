# ── LLM Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# ── DataPilot Internal DB (Railway Postgres or Neon) ──────────────────────────
DATAPILOT_DB_HOST=your-db-host
DATAPILOT_DB_PORT=5432
DATAPILOT_DB_NAME=datapilot
DATAPILOT_DB_USER=datapilot
DATAPILOT_DB_PASSWORD=your-db-password

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change-me-to-a-random-string-in-production

# ── Feature flags ─────────────────────────────────────────────────────────────
# Enable prompt caching in production (net positive under sustained traffic)
ENABLE_PROMPT_CACHING=true
RATE_LIMIT_PER_MINUTE=30

# ── Redis (optional — only needed if you add Redis-based caching) ─────────────
# REDIS_URL=redis://your-redis-host:6379/0
